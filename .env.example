# Supabase — client configuration
# Copy this file to `.env.local` and fill in real values.
# Find both under: Supabase dashboard → Project Settings → API.
#
# The anon/publishable key is SAFE to ship in the frontend — Row-Level Security
# protects the data. NEVER put the service-role key here or in any VITE_ variable;
# it belongs only in Edge Functions / server code.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
